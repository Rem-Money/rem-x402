# =============================================================================
# REM x402 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#
# For testnet: use Base Sepolia values (defaults are already set for testnet).
# For mainnet: see the "Mainnet (Base)" section at the bottom.
# =============================================================================

# -- Network ------------------------------------------------------------------

# JSON-RPC endpoint for the target chain
RPC_URL=https://sepolia.base.org

# CAIP-2 network identifier
#   Base Sepolia (testnet): eip155:84532
#   Base (mainnet):         eip155:8453
NETWORK=eip155:84532

# -- Token --------------------------------------------------------------------

# ERC-20 token contract address on the target chain
TOKEN_ADDRESS=0xYourTokenAddressHere

# Token name — must match the EIP-712 domain name in the token contract
TOKEN_NAME="My Token"

# Token ticker symbol (for display)
TOKEN_SYMBOL=MTK

# Token decimal places (usually 18; USDC uses 6)
TOKEN_DECIMALS=18

# EIP-712 domain version of the token contract (usually "1"; USDC on Base is "2")
TOKEN_VERSION=1

# Transfer method toggle:
#   true  → EIP-3009 (transferWithAuthorization — gasless for the payer)
#   false → Permit2 (requires prior ERC-20 approval to the Permit2 contract)
EIP3009_ENABLED=false

# -- Pricing ------------------------------------------------------------------

# Price per request in the token's smallest unit (e.g. wei, or 10^-6 for USDC)
# Example: 1000000000000000 = 0.001 ETH-scale token; 1000000 = 1.00 USDC
PRICE_AMOUNT=1000000000000000

# -- Wallets ------------------------------------------------------------------

# Private key of the facilitator's settlement wallet.
# This wallet submits on-chain transactions — it must hold ETH for gas.
# ⚠ Never commit this value. Use a dedicated hot-wallet, not your main key.
SETTLEMENT_PRIVATE_KEY=0x...

# Address that receives token payments from users
PAY_TO_ADDRESS=0x...

# -- Service URLs & Ports -----------------------------------------------------

# Facilitator service (internal — the server calls this)
FACILITATOR_URL=http://localhost:4402
FACILITATOR_PORT=4402

# Resource server
SERVER_URL=http://localhost:4401
SERVER_PORT=4401

# -- Frontend (Vite build-time variables) -------------------------------------

# Server URL as reachable from the browser (not the Docker-internal URL)
VITE_SERVER_URL=http://localhost:4401

# WalletConnect Cloud project ID (get one at https://cloud.walletconnect.com)
# The default placeholder works for local dev but will not work in production.
VITE_WALLETCONNECT_PROJECT_ID=x402-poc-demo

# Port the frontend is served on (Docker only — maps to nginx port 80)
FRONTEND_PORT=3000

# -- Contracts (advanced) -----------------------------------------------------

# x402 Permit2 proxy contract — only change if you've deployed your own
# X402_PERMIT2_PROXY=0x402085c248EeA27D92E8b30b2C58ed07f9E20001

# =============================================================================
# Mainnet (Base) quick-start — uncomment and adjust:
# =============================================================================
# RPC_URL=https://mainnet.base.org
# NETWORK=eip155:8453
# TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# TOKEN_NAME=USD Coin
# TOKEN_SYMBOL=USDC
# TOKEN_DECIMALS=6
# TOKEN_VERSION=2
# EIP3009_ENABLED=true
# PRICE_AMOUNT=1000000
